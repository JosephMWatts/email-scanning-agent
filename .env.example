# Copy to .env and fill in. .env is gitignored and never committed.
# The App Password is a 16-character Google App Password (spaces optional).

GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional overrides; defaults shown.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# Absolute path to the Obsidian vault root where scan digests are written.
VAULT_PATH=/path/to/your/obsidian-vault
